{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Booki",
  "version": "0.9.1",
  "identifier": "com.booki.dock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "dock",
        "title": "Booki",
        "url": "index.html",
        "width": 760,
        "height": 240,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "shadow": false,
        "focus": false,
        "visible": true,
        "x": -20000,
        "y": -20000,
        "center": false,
        "dragDropEnabled": true
      },
      {
        "label": "notch",
        "title": "Booki",
        "url": "notch.html",
        "width": 184,
        "height": 26,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "shadow": false,
        "focus": false,
        "visible": true,
        "x": -20000,
        "y": -20000,
        "center": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "publisher": "Booki",
    "copyright": "© 2026 Booki contributors. MIT licensed.",
    "category": "Utility",
    "shortDescription": "A modern, lightweight dock for Windows.",
    "longDescription": "Booki Dock is a cheerful, low-resource dock for Windows: pin your apps, launch or switch to them with a click, with magnify-on-hover, auto-hide and a friendly capybara brand.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerHooks": "installer/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://github.com/punkable/booki/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwQ0JCRTlFQ0M0MDAzQkEKUldTNkEwRE1ucjdMNEZtTER1Q2lNNk5LT1hKbGl0aHZ5Zm1PempSWTZGWk9TWGM0U2toNVNMU2IK"
    }
  }
}
