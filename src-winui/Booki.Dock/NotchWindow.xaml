<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Booki_Dock.NotchWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Booki Dock">
    <Window.SystemBackdrop><DesktopAcrylicBackdrop /></Window.SystemBackdrop>
    <Button Click="Reveal_Click"
            PointerEntered="Reveal_PointerEntered"
            Padding="0"
            Background="{StaticResource BookiSurfaceBrush}"
            BorderBrush="{StaticResource BookiStrokeBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ToolTipService.ToolTip="Mostrar Booki Dock"
            AutomationProperties.Name="Mostrar Booki Dock">
        <Border x:Name="NotchAccent"
                Width="28"
                Height="3"
                CornerRadius="2"
                Background="{StaticResource BookiAccentBrush}"
                Opacity="0.9" />
    </Button>
</Window>