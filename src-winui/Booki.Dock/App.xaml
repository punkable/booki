<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Booki_Dock.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Booki_Dock">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="SettingsCardStyle" TargetType="Border">
                <Setter Property="Padding" Value="12" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
            <SolidColorBrush x:Key="BookiAccentBrush" Color="#DFAA75" />
            <SolidColorBrush x:Key="BookiAccentDeepBrush" Color="#B9875F" />
            <SolidColorBrush x:Key="BookiSurfaceBrush" Color="#E62A292C" />
            <SolidColorBrush x:Key="BookiStrokeBrush" Color="#28FFFFFF" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
