<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Booki_Dock.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid MaxWidth="760" Padding="24,20,24,32" HorizontalAlignment="Stretch">
            <StackPanel x:Name="GeneralPanel" Spacing="16">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="General" />
                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Inicio, integración con Windows y migración." />
                <InfoBar x:Name="MigrationInfo" IsOpen="True" Severity="Informational"
                         Title="Booki Legacy detectado"
                         Message="Puedes importar tus apps y preferencias sin modificar la instalación anterior." />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <ToggleSwitch x:Name="StartWithWindows" Header="Iniciar con Windows" Toggled="StartWithWindows_Toggled" />
                        <InfoBar x:Name="StartupInfo" IsOpen="False" IsClosable="False" />
                        <ToggleSwitch x:Name="ContextMenu" Header="Añadir a Booki desde el Explorador" IsOn="True" Toggled="Setting_Changed" />
                    </StackPanel>
                </Border>
                <Button HorizontalAlignment="Left" Click="ImportLegacy_Click" Content="Importar desde Booki Legacy" />
            </StackPanel>

            <StackPanel x:Name="AppearancePanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Apariencia" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Tema, color y tamaño del dock." />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="14">
                        <ComboBox x:Name="ThemeBox" Header="Tema" SelectionChanged="Setting_Changed">
                            <ComboBoxItem Content="Sistema" Tag="System" />
                            <ComboBoxItem Content="Claro" Tag="Light" />
                            <ComboBoxItem Content="Oscuro" Tag="Dark" />
                        </ComboBox>
                        <StackPanel>
                            <TextBlock Text="Tamaño de iconos" />
                            <Slider x:Name="IconSizeSlider" Minimum="32" Maximum="72" StepFrequency="4"
                                    ValueChanged="Setting_Changed" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Separación" />
                            <Slider x:Name="SpacingSlider" Minimum="0" Maximum="12" StepFrequency="1" ValueChanged="Setting_Changed" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Radio de esquinas" />
                            <Slider x:Name="RadiusSlider" Minimum="6" Maximum="24" StepFrequency="2" ValueChanged="Setting_Changed" />
                        </StackPanel>                        <StackPanel Spacing="8">
                            <TextBlock Text="Color de acento" />
                            <ColorPicker x:Name="AccentPicker"
                                         IsAlphaEnabled="False" ColorChanged="AccentPicker_ColorChanged" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="BehaviorPanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Comportamiento" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Posición, prioridad y respuesta del dock." />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <ComboBox x:Name="EdgeBox" Header="Posición" SelectionChanged="Setting_Changed">
                            <ComboBoxItem Content="Abajo" Tag="Bottom" />
                            <ComboBoxItem Content="Arriba" Tag="Top" />
                            <ComboBoxItem Content="Izquierda" Tag="Left" />
                            <ComboBoxItem Content="Derecha" Tag="Right" />
                        </ComboBox>
                        <ToggleSwitch x:Name="AlwaysOnTop" Header="Flotar por encima de otras ventanas"
                                      Toggled="Setting_Changed" />
                        <ToggleSwitch x:Name="AutoHide" Header="Ocultar automáticamente" Toggled="Setting_Changed" />
                        <ToggleSwitch x:Name="Magnification" Header="Ampliar iconos al pasar el puntero"
                                      Toggled="Setting_Changed" />
                        <StackPanel>
                            <TextBlock Text="Retraso al ocultar" />
                            <Slider x:Name="HideDelaySlider" Minimum="150" Maximum="2000" StepFrequency="50" ValueChanged="Setting_Changed" />
                        </StackPanel>
                        <ComboBox x:Name="NotchTriggerBox" Header="Mostrar desde el notch" SelectionChanged="Setting_Changed">
                            <ComboBoxItem Content="Al hacer clic" Tag="Click" />
                            <ComboBoxItem Content="Al pasar el puntero" Tag="Hover" />
                        </ComboBox>
                        <ToggleSwitch x:Name="ShowLabels" Header="Mostrar nombres" Toggled="Setting_Changed" />
                        <ToggleSwitch x:Name="ShowIndicators" Header="Mostrar indicador de apps abiertas" Toggled="Setting_Changed" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="PinnedPanel" Spacing="16" Visibility="Collapsed">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Apps ancladas" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ordena y edita lo que aparece en el dock." />
                    </StackPanel>
                    <DropDownButton Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" />
                            <TextBlock Text="Añadir" />
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Aplicación" Click="AddApp_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A5;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="Grupo" Click="AddGroup_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8B7;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="Separador" Click="AddSeparator_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE94A;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem Text="Papelera" Click="AddTrash_Click"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon></MenuFlyoutItem>                                <MenuFlyoutSeparator />
                                <MenuFlyoutSubItem Text="Widget">
                                    <MenuFlyoutItem Text="Reloj" Tag="clock" Click="AddWidget_Click" />
                                    <MenuFlyoutItem Text="CPU" Tag="cpu" Click="AddWidget_Click" />
                                    <MenuFlyoutItem Text="Notas" Tag="note" Click="AddWidget_Click" />
                                    <MenuFlyoutItem Text="Portapapeles" Tag="clipboard" Click="AddWidget_Click" />
                                </MenuFlyoutSubItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </Grid>
                <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                         Message="Arrastra las filas para ordenar el dock. Los cambios se guardan automáticamente." />
                <ListView x:Name="PinnedAppsList" CanReorderItems="True" AllowDrop="True"
                          DragItemsCompleted="PinnedAppsList_DragItemsCompleted">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8A5;" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Path}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="2" Click="RemovePinned_Click" Tag="{Binding}" ToolTipService.ToolTip="Quitar">
                                    <FontIcon Glyph="&#xE74D;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel x:Name="UpdatesPanel" Spacing="14" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Actualizaciones" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Booki puede comprobar e instalar nuevas versiones mediante Windows App Installer." />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE895;" FontSize="20" Foreground="{StaticResource BookiAccentBrush}" />
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock FontWeight="SemiBold" Text="Booki Dock" />
                            <TextBlock x:Name="UpdateVersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button x:Name="CheckUpdatesButton" Grid.Column="2" Click="CheckUpdates_Click" Content="Buscar actualizaciones" />
                    </Grid>
                </Border>
                <InfoBar x:Name="UpdateInfo" IsOpen="False" IsClosable="True" />
            </StackPanel>

            <StackPanel x:Name="AboutPanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Acerca de" />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" Background="{ThemeResource BookiAccentBrush}" CornerRadius="8">
                            <Image Source="/Assets/StoreLogo.png" Margin="8" Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Booki Dock" />
                            <TextBlock Text="Dock nativo de Punkable para Windows." />
                            <TextBlock x:Name="VersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
