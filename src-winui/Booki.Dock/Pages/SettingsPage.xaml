<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Booki_Dock.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid MaxWidth="920" Padding="32,24,32,40" HorizontalAlignment="Stretch">
            <StackPanel x:Name="GeneralPanel" Spacing="16">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="General" />
                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Inicio, integración con Windows y migración." />
                <InfoBar x:Name="MigrationInfo" IsOpen="True" Severity="Informational"
                         Title="Booki Legacy detectado"
                         Message="Puedes importar tus apps y preferencias sin modificar la instalación anterior." />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <ToggleSwitch x:Name="StartWithWindows" Header="Iniciar con Windows" />
                        <ToggleSwitch x:Name="ContextMenu" Header="Añadir a Booki desde el Explorador" IsOn="True" />
                    </StackPanel>
                </Border>
                <Button HorizontalAlignment="Left" Click="ImportLegacy_Click" Content="Importar desde Booki Legacy" />
            </StackPanel>

            <StackPanel x:Name="AppearancePanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Apariencia" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Tema, color y tamaño del dock." />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="14">
                        <ComboBox x:Name="ThemeBox" Header="Tema" SelectionChanged="Setting_Changed">
                            <ComboBoxItem Content="Sistema" Tag="System" />
                            <ComboBoxItem Content="Claro" Tag="Light" />
                            <ComboBoxItem Content="Oscuro" Tag="Dark" />
                        </ComboBox>
                        <StackPanel>
                            <TextBlock Text="Tamaño de iconos" />
                            <Slider x:Name="IconSizeSlider" Minimum="32" Maximum="72" StepFrequency="4"
                                    ValueChanged="Setting_Changed" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Color de acento" />
                            <ColorPicker x:Name="AccentPicker"
                                         IsAlphaEnabled="False" ColorChanged="AccentPicker_ColorChanged" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="BehaviorPanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Comportamiento" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Posición, prioridad y respuesta del dock." />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <ComboBox x:Name="EdgeBox" Header="Posición" SelectionChanged="Setting_Changed">
                            <ComboBoxItem Content="Abajo" Tag="Bottom" />
                            <ComboBoxItem Content="Arriba" Tag="Top" />
                            <ComboBoxItem Content="Izquierda" Tag="Left" />
                            <ComboBoxItem Content="Derecha" Tag="Right" />
                        </ComboBox>
                        <ToggleSwitch x:Name="AlwaysOnTop" Header="Flotar por encima de otras ventanas"
                                      Toggled="Setting_Changed" />
                        <ToggleSwitch x:Name="AutoHide" Header="Ocultar automáticamente" Toggled="Setting_Changed" />
                        <ToggleSwitch x:Name="Magnification" Header="Ampliar iconos al pasar el puntero"
                                      Toggled="Setting_Changed" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="PinnedPanel" Spacing="16" Visibility="Collapsed">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Apps ancladas" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Ordena y edita lo que aparece en el dock." />
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Center" Click="AddApp_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" />
                            <TextBlock Text="Añadir app" />
                        </StackPanel>
                    </Button>
                </Grid>
                <ListView x:Name="PinnedAppsList" CanReorderItems="True" AllowDrop="True">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8A5;" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Path}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="2" Click="RemovePinned_Click" Tag="{Binding}" ToolTipService.ToolTip="Quitar">
                                    <FontIcon Glyph="&#xE74D;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel x:Name="AboutPanel" Spacing="16" Visibility="Collapsed">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Acerca de" />
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="28" FontWeight="SemiBold" Text="Booki Dock" />
                        <TextBlock Text="Nueva generación nativa para Windows, construida con WinUI 3." />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="Windows App SDK 2.2 · .NET 10 · Punkable" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
