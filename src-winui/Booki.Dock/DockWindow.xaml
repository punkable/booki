<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Booki_Dock.DockWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Booki_Dock.Models"
    Title="Booki Dock">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Border
        x:Name="DockSurface"
        PointerEntered="DockSurface_PointerEntered"
        PointerExited="DockSurface_PointerExited"
        Padding="6"
        Background="{ThemeResource LayerFillColorAltBrush}"
        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="14">
        <Border.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="Ajustes" Click="OpenSettings_Click">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Salir de Booki Dock" Click="Quit_Click">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8BB;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Border.ContextFlyout>
        <ItemsControl x:Name="PinnedItems">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Click="Tile_Click"
                        Tag="{Binding}"
                        PointerEntered="Tile_PointerEntered"
                        PointerExited="Tile_PointerExited"
                        Width="{Binding TileSize}"
                        Height="{Binding TileSize}"
                        Margin="1"
                        AutomationProperties.Name="{Binding Name}"
                        Background="Transparent"
                        CornerRadius="7"
                        ToolTipService.ToolTip="{Binding Name}">
                        <Button.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Click="OpenItem_Click" Tag="{Binding}">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A7;" /></MenuFlyoutItem.Icon>
                                    Abrir
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="RemoveItem_Click" Tag="{Binding}">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                    Quitar del dock
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.ContextFlyout>
                        <Grid>
                            <Border
                                Width="{Binding ImageSize}"
                                Height="{Binding ImageSize}"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="7" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="{Binding InitialFontSize}"
                                FontWeight="SemiBold"
                                FontFamily="{Binding InitialFontFamily}"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Opacity="{Binding IconOpacity}"
                                Text="{Binding Initial}" />
                            <Image Width="{Binding ImageSize}"
                                   Height="{Binding ImageSize}"
                                   Opacity="{Binding IconOpacity}"
                                   Source="{Binding IconSource}"
                                   Stretch="Uniform" />
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold" Opacity="{Binding WidgetOpacity}"
                                       Text="{Binding WidgetDisplay}" />
                            <Ellipse Width="5" Height="5" Margin="0,0,0,-4"
                                     HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                     Fill="{StaticResource BookiAccentBrush}"
                                     Opacity="{Binding RunningOpacity}" />
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>