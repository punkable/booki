<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Booki_Dock.DockWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Booki_Dock.Models"
    Title="Booki Dock">
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Border
        x:Name="DockSurface"
        PointerEntered="DockSurface_PointerEntered"
        PointerExited="DockSurface_PointerExited"
        Padding="8"
        Background="{ThemeResource LayerFillColorAltBrush}"
        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="Ajustes" Click="OpenSettings_Click">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Salir de Booki Dock" Click="Quit_Click">
                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8BB;" /></MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Border.ContextFlyout>
        <ListView
            x:Name="PinnedList"
            IsItemClickEnabled="True"
            ItemClick="PinnedList_ItemClick"
            SelectionMode="None">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:PinnedItem">
                    <Button
                        PointerEntered="Tile_PointerEntered"
                        PointerExited="Tile_PointerExited"
                        Width="{x:Bind TileSize, Mode=OneWay}"
                        Height="{x:Bind TileSize, Mode=OneWay}"
                        Margin="2"
                        AutomationProperties.Name="{x:Bind Name}"
                        Background="Transparent"
                        CornerRadius="8"
                        ToolTipService.ToolTip="{x:Bind Name}">
                        <Button.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Click="OpenItem_Click" Tag="{x:Bind}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A7;" />
                                    </MenuFlyoutItem.Icon>
                                    Abrir
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="RemoveItem_Click" Tag="{x:Bind}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" />
                                    </MenuFlyoutItem.Icon>
                                    Quitar del dock
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.ContextFlyout>
                        <Grid>
                            <Border
                                Width="{x:Bind ImageSize, Mode=OneWay}"
                                Height="{x:Bind ImageSize, Mode=OneWay}"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="8" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="{x:Bind InitialFontSize, Mode=OneWay}"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Opacity="{x:Bind IconOpacity}"
                                Text="{x:Bind Initial}" />
                            <Image Width="{x:Bind ImageSize, Mode=OneWay}" Height="{x:Bind ImageSize, Mode=OneWay}"
                                   Opacity="{x:Bind IconOpacity}" Source="{x:Bind IconSource, Mode=OneWay}" Stretch="Uniform" />
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="SemiBold" Opacity="{x:Bind WidgetOpacity}"
                                       Text="{x:Bind WidgetDisplay, Mode=OneWay}" />
                            <Ellipse Width="5" Height="5" Margin="0,0,0,-6"
                                     HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                     Fill="{StaticResource BookiAccentBrush}"
                                     Opacity="{x:Bind RunningOpacity, Mode=OneWay}" />
                        </Grid>
                    </Button>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Border>
</Window>
