{
  "manifest_version": 3,
  "name": "Booki",
  "description": "A cheerful bookmark manager with cross-device sync.",
  "version": "2.0.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Booki",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "omnibox": {
    "keyword": "booki"
  },
  "permissions": [
    "bookmarks",
    "contextMenus",
    "favicon",
    "sidePanel",
    "storage",
    "tabs",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "http://*/",
    "https://*/"
  ],
  "commands": {
    "open-studio": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Open Booki"
    }
  }
}
